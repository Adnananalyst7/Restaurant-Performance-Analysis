      <aliases enabled='yes' />
      <column caption='Price Range description' datatype='string' name='[Calculation_1330813725805326336]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [price_range] = 1 THEN &apos;Cheap&apos; &#13;&#10;ELSEIF [price_range] = 2 THEN &apos;Less Expensive&apos;&#13;&#10;ELSEIF [price_range] = 3 THEN &apos;Expensive&apos;&#13;&#10;ELSE &apos;Luxurious&apos;&#13;&#10;END' />
      </column>
      <column caption='distinct rating' datatype='integer' name='[Calculation_1330813725818142721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([aggregate_rating])' />
      </column>
      <column caption='Online Delivery' datatype='integer' name='[Calculation_1330813725835923458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [has_online_delivery] = &apos;Yes&apos; then 1 ELSE 0 END' />
      </column>
      <column caption='Table booking' datatype='integer' name='[Calculation_1330813725836206083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [has_table_booking] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Restaurant count' datatype='integer' name='[Calculation_1851823916856180738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([restaurant_name])' />
      </column>
      <column caption='National Presence' datatype='integer' name='[Calculation_1851823916862820355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [restaurant_name] : COUNTD([city])}' />
      </column>
      <column caption='Total Restaurants' datatype='integer' name='[Calculation_1851823916875505670]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([restaurant_name])' />
      </column>
      <column caption='Average Ratings' datatype='real' name='[Calculation_1851823916876087303]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([aggregate_rating])' />
      </column>
      <column caption='No cuisines' datatype='integer' name='[No_cuisines]' role='measure' type='quantitative' />
